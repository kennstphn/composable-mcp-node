{
  "name": "composable-mcp-node",
  "engines": {
    "node": ">=22.11.0"
  },
  "version": "0.3.0",
  "description": "A Node.js HTTP server that exposes composed tools as MCP endpoints",
  "type": "module",
  "main": "main.mjs",
  "scripts": {
    "build": "node build.mjs",
    "start": "node main.mjs",
    "start:pm2": "pm2 start main.mjs --name composable-mcp-node",
    "stop": "pm2 stop composable-mcp-node",
    "restart": "pm2 restart composable-mcp-node",
    "logs": "pm2 logs composable-mcp-node",
    "test": "node --test"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "cookie": "^1.1.1",
    "dompurify": "^3.3.3",
    "dotenv": "^17.3.1",
    "esbuild": "^0.28.0",
    "express": "^5.2.1",
    "express-ws": "^5.0.2",
    "marked": "^17.0.5",
    "mustache": "^4.2.0",
    "pm2": "^6.0.14",
    "prismjs": "^1.30.0"
  }
}
