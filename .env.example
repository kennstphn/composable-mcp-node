# Port the HTTP server listens on (default: 8787)
PORT=8787

# The ROUTES_PREFIX variable is used to specify a base path for the application. If you want to serve this app under a specific
# path (e.g. http://localhost:8787/composable-mcp), you can set PREFIX=/composable-mcp. If you want to serve it at the
# root (e.g. http://localhost:8787/), you can leave PREFIX empty or unset it.
# ROUTES_PREFIX=/composable-mcp

# Base URL of the Directus instance (required)
DIRECTUS_BASE_URL=http://localhost:8055

# Node environment (e.g. development, production, test)
NODE_ENV=development

#these next two settings are for forcing HTTPS and trusting proxy headers, which are important for production deployments
# but not usually needed for local development. You can set them to true in production if your instance is
# served over HTTPS and/or behind a proxy that handles HTTPS.

# Whether to force HTTPS (default: false for development)
# Set to true in production if your Directus instance is served over HTTPS
FORCE_HTTPS=false

# Whether to trust the X-Forwarded-* headers (default: false)
# Set to true if your app is behind a proxy (e.g. Nginx) that handles HTTPS and forwards requests to your app over HTTP
# set directly to express app.set('trust proxy', TRUST_PROXY), so use a valid express variable
# eg loopback, unique_local, true
TRUST_PROXY=false

# If your app is served under a specific path (e.g. http://localhost:8787/composable-mcp), set the ROUTES_PREFIX to that path.
# If your app is served at the root (e.g. http://localhost:8787/), you can leave ROUTES_PREFIX empty or unset it.
# ROUTES_PREFIX=/composable-mcp